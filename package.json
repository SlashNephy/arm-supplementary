{
  "name": "arm-supplementary",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SlashNephy/arm-supplementary"
  },
  "license": "MIT",
  "author": "SlashNephy",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "pnpm run generate:code && pnpm run generate:json && pnpm run generate:readme && eslint --fix",
    "generate:code": "pnpm run source",
    "generate:json": "node --experimental-strip-types bin/generateJson.ts",
    "generate:readme": "node --experimental-strip-types bin/generateReadme.ts",
    "graphql": "pnpm run graphql:annict:schema && pnpm run graphql:codegen",
    "graphql:annict:schema": "curl -o graphql/annict/schema.graphql https://raw.githubusercontent.com/annict/annict/refs/heads/develop/rails/app/graphql/beta/schema.graphql",
    "graphql:codegen": "graphql-codegen --config graphql/codegen.ts",
    "source": "pnpm run /source:.*/",
    "source:anime-offline-database": "node --experimental-strip-types bin/anime-offline-database.ts",
    "source:annict": "node --experimental-strip-types bin/annict.ts"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "fzstd": "0.1.1",
    "graphql-request": "7.4.0",
    "mdast-builder": "1.1.1",
    "remark-gfm": "4.0.1",
    "remark-stringify": "11.0.0",
    "unified": "11.0.5",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@slashnephy/eslint-config": "3.0.307",
    "@types/mdast": "4.0.4",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "graphql": "16.13.2",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">= 24"
  }
}
